# Database (PostgreSQL) — required for API routes that save data
#
# Supabase (recommended for Vercel serverless):
# - Dashboard → Project Settings → Database → copy the "Connection string"
# - Use the "Transaction pooler" / port 6543 URI for serverless (NOT session pooler on 5432 for high traffic)
# - Replace [YOUR-PASSWORD] with the database password
# Example shape:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# If npm run db:init fails with ENETUNREACH to an IPv6 address (2600:...), either:
# - scripts/create-pg-pool.js resolves A records and connects via IPv4 when possible, or
# - use the Transaction pooler URI (port 6543) from the dashboard, or
# - enable Supabase IPv4 add-on, or
# - run schema SQL in Supabase Dashboard → SQL (no local DB connection needed).
# To skip IPv4 forcing: DB_INIT_FORCE_IPV4=0
DATABASE_URL=postgresql://user:password@host:5432/sea_regent

# Supabase Auth (login with ship login_id; passwords live in Auth, not ships.password_hash)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Some hosts (e.g. Supabase Vercel integration) only set these — the app accepts them too:
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Publishable key from Dashboard → API (or legacy anon JWT):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
# Optional aliases:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_ANON_KEY=eyJ...
# Service role — server/scripts ONLY (e.g. npm run db:seed). Never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Synthetic email domain for Auth (login_id@domain). Must match between Vercel and seed script.
# Default in code: ship.auth.invalid
# SHIP_AUTH_EMAIL_DOMAIN=ship.auth.invalid

# AWS Cognito — optional; legacy if unused
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-2_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-2

# Admin email notification (for password changes)
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="SYS OIL AND PETROLEUMS CORP <no-reply@example.com>"
